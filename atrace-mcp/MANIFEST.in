# MANIFEST.in — controls what goes into the sdist (source distribution)
# Wheel packaging uses pyproject.toml [tool.setuptools.package-data]

# Core Python source
include *.py
include requirements.txt
include README.md
include pyproject.toml

# Bundled JVM tool (built by ./gradlew deployMcp before packaging)
include bin/atrace-tool.jar
include bin/README.md

# Perfetto system trace capture scripts
include scripts/record_android_trace
include scripts/record_android_trace_win
include scripts/README.md
include scripts/serve_trace_for_perfetto.py

# simpleperf toolkit (recursive)
recursive-include simpleperf_toolkit *

# Exclude dev/test artifacts
exclude test_*.py
global-exclude __pycache__
global-exclude *.pyc
global-exclude *.pyo
global-exclude .DS_Store
prune dist
prune build
prune *.egg-info
